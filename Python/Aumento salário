s = float(input())


if s <= 400.00:
    percentual = 15
elif s <= 800.00:
    percentual = 12
elif s <= 1200.00:
    percentual = 10
elif s <= 2000.00:
    percentual = 7
else:
    percentual = 4


reajuste = s * (percentual / 100)
novo_salario = s + reajuste


print(f"Novo salario: {novo_salario:.2f}")
print(f"Reajuste ganho: {reajuste:.2f}")
print(f"Em percentual: {percentual} %")